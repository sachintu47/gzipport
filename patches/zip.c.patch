diff --git a/zip.c b/zip.c
index eb42982..d1eee0d 100644
--- a/zip.c
+++ b/zip.c
@@ -21,6 +21,9 @@
 
 #include "tailor.h"
 #include "gzip.h"
+#ifdef __MVS__
+#include "zos.h"
+#endif
 
 off_t header_bytes;   /* number of bytes in gzip header */
 
@@ -55,6 +58,13 @@ zip (int in, int out)
     if (save_orig_name) {
         flags |= ORIG_NAME;
     }
+
+#ifdef __MVS__
+    zos_extra_field_t *zz = zos_get_extra_field();
